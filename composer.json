{
  "name": "bagdock/bagdock-php",
  "description": "Official Bagdock API client for PHP",
  "type": "library",
  "license": "MIT",
  "homepage": "https://docs.bagdock.com/sdks/php",
  "keywords": ["bagdock", "sdk", "api", "self-storage"],
  "authors": [
    { "name": "Bagdock", "email": "engineering@bagdock.com" }
  ],
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Bagdock\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Bagdock\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  }
}
